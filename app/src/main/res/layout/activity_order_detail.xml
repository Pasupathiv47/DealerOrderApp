<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/orderDetailText" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:fontFamily="monospace"/>
    </ScrollView>

    <Button android:id="@+id/btnCopy" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Copy Order" android:layout_marginTop="12dp"/>
    <Button android:id="@+id/btnShare" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Share Order" android:layout_marginTop="8dp"/>
    <Button android:id="@+id/btnDelete" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Delete Order" android:layout_marginTop="8dp"/>
</LinearLayout>
