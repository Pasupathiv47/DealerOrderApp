<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Location:" android:textStyle="bold"/>
    <Spinner android:id="@+id/locationSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Dealer:" android:textStyle="bold"/>
    <Spinner android:id="@+id/dealerSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnAddLine" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Add Item to Order" android:layout_marginBottom="8dp"/>

    <ListView android:id="@+id/lineListView" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <Button android:id="@+id/btnSaveOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Save Order" android:layout_marginTop="8dp"/>
</LinearLayout>
