<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText android:id="@+id/categoryName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Category name (e.g. Laptops)"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Variant Type" android:textStyle="bold" android:layout_marginTop="8dp"/>
    <Spinner android:id="@+id/categoryTypeSpinner" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
