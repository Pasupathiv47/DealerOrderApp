<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dealer Order Manager"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnDealers" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Manage Dealers" android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnItems" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Manage Items" android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnNewOrder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="New Order" android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnOrders" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Order History"/>
</LinearLayout>
