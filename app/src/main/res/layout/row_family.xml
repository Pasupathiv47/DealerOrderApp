<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:descendantFocusability="blocksDescendants">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="6dp">
        <TextView android:id="@+id/familyRowText" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp"/>
        <TextView android:id="@+id/familyRowSubtext" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#777777"/>
    </LinearLayout>

    <Button android:id="@+id/familyMoveBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Move" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/familyDeleteBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delete"/>
</LinearLayout>
