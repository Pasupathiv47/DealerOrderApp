<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText android:id="@+id/variantOptionInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="e.g. 8GB+128GB or 32 inch"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Type" android:textStyle="bold" android:layout_marginTop="8dp"/>
    <Spinner android:id="@+id/variantOptionTypeSpinner" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
