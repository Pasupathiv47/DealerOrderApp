<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cloud Sync"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Push sends your item catalog (names, brands, variants) to the cloud so office staff can see them. Pull brings back the latest price and stock updates they've entered."
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btnPushCatalog" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Push Catalog to Cloud" android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnPullPriceStock" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pull Prices &amp; Stock from Cloud" android:layout_marginBottom="24dp"/>

    <TextView android:id="@+id/syncStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="italic"/>
</LinearLayout>
