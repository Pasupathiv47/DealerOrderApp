<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:descendantFocusability="blocksDescendants">

    <TextView android:id="@+id/orderRowText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp"/>
    <Button android:id="@+id/orderRowCopyBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Copy" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/orderRowEditBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Edit" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/orderRowDeleteBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delete"/>
</LinearLayout>
